        "kind": "Panel",
        "spec": {
          "data": {
            "kind": "QueryGroup",
            "spec": {
              "queries": [
                {
                  "kind": "PanelQuery",
                  "spec": {
                    "datasource": {
                      "type": "prometheus",
                      "uid": "${datasource}"
                    },
                    "hidden": false,
                    "query": {
                      "kind": "prometheus",
                      "spec": {
                        "editorMode": "code",
                        "expr": "histogram_quantile(0.95, sum by (le, collector) (rate(meraki_exporter_collector_duration_seconds_bucket{job=\"meraki_dashboard\", instance=~\"$instance\"}[$__rate_interval])))",
                        "legendFormat": "{{collector}}",
                        "range": true
                      }
                    },
                    "refId": "A"
                  }
                }
              ],
              "queryOptions": {},
              "transformations": []
            }
          },
          "description": "",
          "id": 1,
          "links": [],
          "title": "Collector run duration p95 (s)",
          "vizConfig": {
            "kind": "timeseries",
            "spec": {
              "fieldConfig": {
                "defaults": {
                  "color": {
                    "mode": "palette-classic"
                  },
                  "custom": {
                    "drawStyle": "line",
                    "fillOpacity": 12,
                    "lineWidth": 1,
