                    "hidden": false,
                    "query": {
                      "kind": "prometheus",
                      "spec": {
                        "editorMode": "code",
                        "expr": "rate(meraki_exporter_client_dns_resolution_seconds_total{job=\"meraki_dashboard\"}[$__rate_interval]) / clamp_min(rate(meraki_exporter_client_dns_lookups_total{job=\"meraki_dashboard\"}[$__rate_interval]) - rate(meraki_exporter_client_dns_lookups_cached_total{job=\"meraki_dashboard\"}[$__rate_interval]), 1)",
                        "legendFormat": "{{instance}}",
                        "range": true
                      }
                    },
                    "refId": "A"
                  }
                }
              ],
              "queryOptions": {},
              "transformations": []
            }
          },
          "description": "Average reverse-DNS resolution latency, excluding cache hits (process-wide).",
          "id": 14,
          "links": [],
          "title": "DNS Resolution Latency (avg)",
          "vizConfig": {
            "kind": "timeseries",
            "spec": {
              "fieldConfig": {
                "defaults": {
                  "color": {
                    "mode": "palette-classic"
