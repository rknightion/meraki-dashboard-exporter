                    "hidden": false,
                    "query": {
                      "kind": "prometheus",
                      "spec": {
                        "editorMode": "code",
                        "expr": "sum by (instance) (rate(meraki_exporter_client_dns_lookups_successful_total{job=\"meraki_dashboard\"}[$__rate_interval]))",
                        "legendFormat": "successful {{instance}}",
