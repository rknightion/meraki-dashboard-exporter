{
  "apiVersion": "dashboard.grafana.app/v2alpha1",
  "kind": "Dashboard",
  "metadata": {
    "annotations": {
      "grafana.app/folder": "meraki-exporter"
    },
    "name": "meraki-clients"
  },
  "spec": {
    "annotations": [],
    "cursorSync": "Off",
    "description": "Bounded, fleet-shaped client metrics from the scrape path: counts, SSID/VLAN distribution, usage aggregates, and exporter DNS/client-store health.",
    "editable": true,
    "elements": {
      "panel-1": {
        "kind": "Panel",
        "spec": {
          "data": {
            "kind": "QueryGroup",
            "spec": {
              "queries": [
                {
                  "kind": "PanelQuery",
                  "spec": {
                    "datasource": {
                      "type": "prometheus",
                      "uid": "${datasource}"
                    },
                    "hidden": false,
                    "query": {
                      "kind": "prometheus",
                      "spec": {
                        "editorMode": "code",
                        "expr": "sum(meraki_client_status{job=\"meraki_dashboard\", org_id=~\"$organization\", network_id=~\"$network\"} == 1)",
                        "legendFormat": "Online",
                        "range": true
                      }
                    },
                    "refId": "A"
                  }
                }
              ],
              "queryOptions": {},
              "transformations": []
            }
          },
          "description": "Count of clients currently reporting online status.",
          "id": 1,
          "links": [],
          "title": "Clients Online",
          "vizConfig": {
            "kind": "stat",
            "spec": {
              "fieldConfig": {
                "defaults": {},
                "overrides": null
              },
              "options": {
                "colorMode": "background",
                "graphMode": "area",
                "justifyMode": "auto",
                "reduceOptions": {
                  "calcs": [
                    "lastNotNull"
                  ],
                  "fields": "",
                  "values": false
                },
                "textMode": "auto"
              },
              "pluginVersion": ""
            }
          }
        }
      },
      "panel-10": {
        "kind": "Panel",
        "spec": {
          "data": {
            "kind": "QueryGroup",
            "spec": {
              "queries": [
                {
                  "kind": "PanelQuery",
                  "spec": {
                    "datasource": {
                      "type": "prometheus",
                      "uid": "${datasource}"
                    },
                    "hidden": false,
                    "query": {
                      "kind": "prometheus",
                      "spec": {
                        "editorMode": "code",
                        "expr": "topk(10, meraki_client_usage_total_bytes{job=\"meraki_dashboard\", org_id=~\"$organization\", network_id=~\"$network\"})",
                        "legendFormat": "{{client_id}}",
                        "range": true
                      }
                    },
                    "refId": "A"
                  }
                }
              ],
              "queryOptions": {},
              "transformations": []
            }
          },
          "description": "Top-N (bounded) client IDs by total bytes transferred in the last hour.",
          "id": 10,
          "links": [],
          "title": "Top 10 Clients by Usage",
          "vizConfig": {
            "kind": "bargauge",
            "spec": {
              "fieldConfig": {
                "defaults": {
                  "unit": "bytes"
                },
                "overrides": null
              },
              "options": {
                "displayMode": "gradient",
                "orientation": "horizontal",
                "reduceOptions": {
                  "calcs": [
                    "lastNotNull"
                  ],
                  "fields": "",
                  "values": false
                }
              },
              "pluginVersion": ""
            }
          }
        }
      },
      "panel-11": {
        "kind": "Panel",
        "spec": {
          "data": {
            "kind": "QueryGroup",
            "spec": {
              "queries": [
                {
                  "kind": "PanelQuery",
                  "spec": {
                    "datasource": {
                      "type": "prometheus",
                      "uid": "${datasource}"
                    },
                    "hidden": false,
                    "query": {
                      "kind": "prometheus",
                      "spec": {
                        "editorMode": "code",
                        "expr": "topk(10, sum by (type) (meraki_client_application_usage_total_bytes{job=\"meraki_dashboard\", org_id=~\"$organization\", network_id=~\"$network\"}))",
                        "legendFormat": "{{type}}",
                        "range": true
                      }
                    },
                    "refId": "A"
                  }
                }
              ],
              "queryOptions": {},
              "transformations": []
            }
          },
          "description": "Top-N (bounded) application categories by total bytes transferred in the last hour.",
          "id": 11,
          "links": [],
          "title": "Application Usage Breakdown (Top 10)",
          "vizConfig": {
            "kind": "piechart",
            "spec": {
              "fieldConfig": {
                "defaults": {
                  "unit": "bytes"
                },
                "overrides": null
              },
              "options": {
                "legend": {
                  "displayMode": "table",
                  "placement": "right",
                  "values": [
                    "value",
                    "percent"
                  ]
                },
                "pieType": "donut",
                "reduceOptions": {
                  "calcs": [
                    "lastNotNull"
                  ],
                  "fields": "",
                  "values": false
                }
              },
              "pluginVersion": ""
            }
          }
        }
      },
      "panel-12": {
        "kind": "Panel",
        "spec": {
          "data": {
            "kind": "QueryGroup",
            "spec": {
              "queries": [
                {
                  "kind": "PanelQuery",
                  "spec": {
                    "datasource": {
                      "type": "prometheus",
                      "uid": "${datasource}"
                    },
                    "hidden": false,
                    "query": {
                      "kind": "prometheus",
                      "spec": {
                        "editorMode": "code",
                        "expr": "meraki_exporter_client_dns_cache_hit_ratio{job=\"meraki_dashboard\"}",
                        "legendFormat": "{{instance}}",
                        "range": true
                      }
                    },
                    "refId": "A"
                  }
                }
              ],
              "queryOptions": {},
              "transformations": []
            }
          },
          "description": "Ratio of reverse-DNS lookups served from cache, cumulative over process lifetime (process-wide; not org/network filterable).",
          "id": 12,
          "links": [],
          "title": "DNS Cache Hit Ratio",
          "vizConfig": {
            "kind": "gauge",
            "spec": {
              "fieldConfig": {
                "defaults": {
                  "max": 1,
                  "min": 0,
                  "unit": "percentunit"
                },
                "overrides": null
              },
              "options": {
                "reduceOptions": {
                  "calcs": [
                    "lastNotNull"
                  ],
                  "fields": "",
                  "values": false
                },
                "showThresholdLabels": false,
                "showThresholdMarkers": true
              },
              "pluginVersion": ""
            }
          }
        }
      },
      "panel-13": {
        "kind": "Panel",
        "spec": {
          "data": {
            "kind": "QueryGroup",
            "spec": {
              "queries": [
                {
                  "kind": "PanelQuery",
                  "spec": {
                    "datasource": {
                      "type": "prometheus",
