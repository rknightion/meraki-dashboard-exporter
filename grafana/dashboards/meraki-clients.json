          "title": "DNS Lookups Rate",
          "vizConfig": {
            "kind": "timeseries",
            "spec": {
              "fieldConfig": {
                "defaults": {
                  "color": {
                    "mode": "palette-classic"
                  },
                  "custom": {
                    "drawStyle": "line",
                    "fillOpacity": 12,
                    "lineWidth": 1,
                    "showPoints": "never"
                  }
                },
                "overrides": null
              },
              "options": {},
              "pluginVersion": ""
            }
          }
        }
      },
      "panel-14": {
        "kind": "Panel",
        "spec": {
          "data": {
            "kind": "QueryGroup",
            "spec": {
              "queries": [
                {
                  "kind": "PanelQuery",
                  "spec": {
                    "datasource": {
                      "type": "prometheus",
                      "uid": "${datasource}"
