# Snyk (https://snyk.io) policy file.
# Schema: only `version`, `ignore`, `patches` and `exclude` are honoured by Snyk.
version: v1.25.0

# Accepted-risk findings (with justification + expiry).
ignore:
  python/PT:
    - '*':
        reason: >-
          tools/apidrift is a dev/CI-only CLI tool. The flagged sink is the
          --emit-reduced output directory, an operator-supplied CLI argument
          (no trust boundary is crossed) and the written filenames are
          hardcoded (baseline.json / live.json), so nothing escapes the
          chosen directory.
        expires: 2027-06-29T00:00:00.000Z

patches: {}
