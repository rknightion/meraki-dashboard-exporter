{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "customManagers": [
    {
      "customType": "regex",
      "description": "Track the pinned uv version in the Dockerfile UV_VERSION ARG.",
      "managerFilePatterns": ["/^Dockerfile$/"],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>\\S+) depName=(?<depName>\\S+)\\s+ARG UV_VERSION=(?<currentValue>\\S+)"
      ]
    }
  ],
  "packageRules": [
    {
      "description": "Rebase GitHub Actions PRs only when conflicted (override the fleet default)",
      "matchManagers": ["github-actions"],
      "rebaseWhen": "conflicted"
    },
    {
      "description": "Track OpenTelemetry pre-release versions",
      "ignoreUnstable": false,
      "labels": ["dep:opentelemetry"],
      "matchPackageNames": ["/^opentelemetry/"]
    },
    {
      "description": "OpenTelemetry Python packages (api, sdk, exporter-otlp, instrumentation-*) release in lockstep — group them into one PR.",
      "matchPackageNames": ["/^opentelemetry/"],
      "groupName": "opentelemetry"
    }
  ]
}
