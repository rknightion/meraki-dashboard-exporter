# Meraki Dashboard Exporter - environment variable reference
#
# GENERATED by scripts/generate_env_example.py from the Pydantic config
# models (the same source as docs/config.md). DO NOT EDIT BY HAND - run
# `make docgen` to regenerate. Every settable variable is listed here,
# commented at its default; uncomment and change what you need. Required
# variables are shown uncommented with an empty value.
#
# Nested config uses `__` (double underscore): MERAKI_EXPORTER_<SECTION>__<SETTING>.

# ==========================================================================
# MERAKI API (required key + org/region)
# Meraki API configuration.
# ==========================================================================

# Meraki Dashboard API key
# REQUIRED - set this.
MERAKI_EXPORTER_MERAKI__API_KEY=

# Meraki organization ID. For v1 the single-organization contract applies (one
# poller instance = one organization): when the API key sees exactly one org
# it is auto-selected and org_id may be omitted; when the key sees several
# orgs, set org_id explicitly (startup fails fast on an ambiguous multi-org
# key). See discovery.py/app startup.
# MERAKI_EXPORTER_MERAKI__ORG_ID=

# Meraki API base URL (use regional endpoints if needed)
# MERAKI_EXPORTER_MERAKI__API_BASE_URL=https://api.meraki.com/api/v1

# ==========================================================================
# LOGGING
# Logging configuration.
# ==========================================================================

# Logging level (case-insensitive; normalised to upper-case)
# MERAKI_EXPORTER_LOGGING__LEVEL=INFO

# Structured-log renderer: 'logfmt' (default) or 'json'.
# MERAKI_EXPORTER_LOGGING__LOG_FORMAT=logfmt

# ==========================================================================
# MERAKI API TUNING (retries, batching, concurrency, rate limiting)
# API-related configuration settings.
# ==========================================================================

# Maximum number of retries for API requests (min: 0, max: 10)
# MERAKI_EXPORTER_API__MAX_RETRIES=3

# Per-request API timeout in seconds (SDK single_request_timeout). Note this
# applies to EACH page request, so a total_pages='all' bulk fetch may make
# many such requests; the overall fetch is additionally bounded by
# per_fetch_deadline_seconds. Reviewed for large-org bulk fetches (#556): kept
# at 30s (raise only if large-org page latencies are observed to exceed it).
# (min: 10, max: 300)
# MERAKI_EXPORTER_API__TIMEOUT=30

# Maximum concurrent API requests (global fallback) (min: 1, max: 20)
# MERAKI_EXPORTER_API__CONCURRENCY_LIMIT=5

# Maximum concurrent API requests for FAST tier collectors (min: 1, max: 20)
# MERAKI_EXPORTER_API__CONCURRENCY_LIMIT_FAST=5

# Maximum concurrent API requests for MEDIUM tier collectors (min: 1, max: 20)
# MERAKI_EXPORTER_API__CONCURRENCY_LIMIT_MEDIUM=3

# Maximum concurrent API requests for SLOW tier collectors (min: 1, max: 20)
# MERAKI_EXPORTER_API__CONCURRENCY_LIMIT_SLOW=2

# Default batch size for API operations (min: 1, max: 100)
# MERAKI_EXPORTER_API__BATCH_SIZE=20

# Batch size for device operations (min: 1, max: 100)
# MERAKI_EXPORTER_API__DEVICE_BATCH_SIZE=20

# Batch size for network operations (min: 1, max: 100)
# MERAKI_EXPORTER_API__NETWORK_BATCH_SIZE=30

# Batch size for client operations (e.g., MR client metrics) (min: 1, max:
# 100)
# MERAKI_EXPORTER_API__CLIENT_BATCH_SIZE=20

# Delay between batches in seconds (min: 0.0, max: 5.0)
# MERAKI_EXPORTER_API__BATCH_DELAY=0.5

# Wait time in seconds when rate limited (min: 1, max: 60)
# MERAKI_EXPORTER_API__RATE_LIMIT_RETRY_WAIT=5

# Wait time for action batch retries (min: 1, max: 60)
# MERAKI_EXPORTER_API__ACTION_BATCH_RETRY_WAIT=10

# When True, the Meraki SDK logs warnings if API methods are called with
# unrecognized kwargs. Recommended for dev/CI; off by default in production.
# MERAKI_EXPORTER_API__VALIDATE_KWARGS=false

# HTTPS proxy URL for Meraki API requests (SDK requests_proxy); when unset the
# requests HTTPS_PROXY/NO_PROXY env vars still apply.
# MERAKI_EXPORTER_API__REQUESTS_PROXY=

# Path to a custom CA bundle for verifying the Meraki API TLS cert (SDK
# certificate_path); mount into read-only containers as a volume.
# MERAKI_EXPORTER_API__CERTIFICATE_PATH=

# Enable client-side rate limiting to smooth API calls
# MERAKI_EXPORTER_API__RATE_LIMIT_ENABLED=true

# Target requests per second per organization (min: 1.0, max: 50.0)
# MERAKI_EXPORTER_API__RATE_LIMIT_REQUESTS_PER_SECOND=10.0

# Token bucket burst capacity per organization (min: 1, max: 100)
# MERAKI_EXPORTER_API__RATE_LIMIT_BURST=20

# Fraction of the org API call budget this exporter is allowed to consume.
# Defaults to 0.8 so ~20% headroom is left for other consumers of the same org
# budget (dashboards, other tools, humans); set to 1.0 to claim the whole
# budget (#550). (min: 0.1, max: 1.0)
# MERAKI_EXPORTER_API__RATE_LIMIT_SHARED_FRACTION=0.8

# Jitter ratio applied to client-side rate limiter waits (min: 0.0, max: 0.5)
# MERAKI_EXPORTER_API__RATE_LIMIT_JITTER_RATIO=0.1

# Spread batch work across the collection interval
# MERAKI_EXPORTER_API__SMOOTHING_ENABLED=true

# Fraction of the collection interval used for smoothing (min: 0.1, max: 1.0)
# MERAKI_EXPORTER_API__SMOOTHING_WINDOW_RATIO=0.8

# Minimum delay between batches when smoothing (min: 0.0, max: 60.0)
# MERAKI_EXPORTER_API__SMOOTHING_MIN_BATCH_DELAY=1.0

# Maximum delay between batches when smoothing (min: 0.0, max: 300.0)
# MERAKI_EXPORTER_API__SMOOTHING_MAX_BATCH_DELAY=15.0

# Use org-level switch port status endpoint for MS status metrics
# MERAKI_EXPORTER_API__MS_PORT_STATUS_USE_ORG_ENDPOINT=true

# Minimum seconds between per-switch port usage/POE refreshes (min: 0, max:
# 3600)
# MERAKI_EXPORTER_API__MS_PORT_USAGE_INTERVAL=600

# Minimum seconds between per-switch packet stats refreshes (min: 0, max:
# 3600)
# MERAKI_EXPORTER_API__MS_PACKET_STATS_INTERVAL=600

# Minimum seconds between client application usage refreshes (min: 0, max:
# 3600)
# MERAKI_EXPORTER_API__CLIENT_APP_USAGE_INTERVAL=600

# Minimum seconds between per-client wireless signal-quality refreshes (min:
# 0, max: 3600)
# MERAKI_EXPORTER_API__CLIENT_SIGNAL_QUALITY_INTERVAL=600

# Maximum wireless clients queried for signal quality per network per cycle (0
# disables the cap). Bounds the sequential per-client API fan-out. (min: 0,
# max: 5000)
# MERAKI_EXPORTER_API__CLIENT_SIGNAL_QUALITY_MAX_CLIENTS=200

# Upper bound (seconds) honoured for a server-sent Retry-After header when
# backing off a throttled (429/503) request. Caps pathological Retry-After
# values so a single throttled request cannot stall a collection cycle
# indefinitely. (min: 1, max: 3600)
# MERAKI_EXPORTER_API__RETRY_AFTER_MAX_SECONDS=60

# Size of the thread pool used to run the synchronous Meraki SDK off the event
# loop (the asyncio.to_thread executor). Bounds the number of concurrent
# blocking SDK calls independently of the per-tier API concurrency limits.
# (min: 1, max: 100)
# MERAKI_EXPORTER_API__EXECUTOR_WORKERS=10

# Wall-clock deadline (seconds) for a single logical fetch, including all
# paginated page requests made under total_pages='all'. Sits between the SDK
# per-request timeout (see 'timeout') and the per-collector timeout so a slow
# bulk fetch fails fast instead of consuming the whole collector budget. (min:
# 1, max: 600)
# MERAKI_EXPORTER_API__PER_FETCH_DEADLINE_SECONDS=120

# ==========================================================================
# COLLECTOR UPDATE INTERVALS (per tier, seconds)
# Update interval configuration with validation.
# ==========================================================================

# Interval for fast-moving data (sensors) in seconds (min: 30, max: 300)
# MERAKI_EXPORTER_UPDATE_INTERVALS__FAST=60

# Interval for medium-moving data (device metrics) in seconds (min: 300, max:
# 1800)
# MERAKI_EXPORTER_UPDATE_INTERVALS__MEDIUM=300

# Interval for slow-moving data (configuration) in seconds (min: 600, max:
# 3600)
# MERAKI_EXPORTER_UPDATE_INTERVALS__SLOW=900

# ==========================================================================
# HTTP SERVER
# HTTP server configuration.
# ==========================================================================

# Host to bind the exporter to
# MERAKI_EXPORTER_SERVER__HOST=0.0.0.0

# Port to bind the exporter to (min: 1, max: 65535)
# MERAKI_EXPORTER_SERVER__PORT=9099

# Optional bearer token required for state-changing POST control endpoints
# (/api/collectors/trigger, /api/clients/clear-dns-cache). When unset
# (default) these endpoints are unauthenticated - bind the exporter to a
# trusted interface. When set, requests must present 'Authorization: Bearer
# <token>'.
# MERAKI_EXPORTER_SERVER__API_TOKEN=

# When false, sensitive GET UI/status endpoints return 404
# (metrics/health/ready stay open).
# MERAKI_EXPORTER_SERVER__UI_ENABLED=true

# ==========================================================================
# WEBHOOK RECEIVER
# Webhook receiver configuration.
# ==========================================================================

# Enable webhook receiver endpoint
# MERAKI_EXPORTER_WEBHOOKS__ENABLED=false

# Shared secret for webhook validation (recommended)
# MERAKI_EXPORTER_WEBHOOKS__SHARED_SECRET=

# Require shared secret validation (disable for testing only)
# MERAKI_EXPORTER_WEBHOOKS__REQUIRE_SECRET=true

# Explicit opt-in to run the webhook receiver enabled without require_secret;
# startup refuses the insecure combo unless this is true.
# MERAKI_EXPORTER_WEBHOOKS__ALLOW_INSECURE=false

# Maximum webhook payload size in bytes (min: 1024, max: 10485760)
# MERAKI_EXPORTER_WEBHOOKS__MAX_PAYLOAD_SIZE=1048576

# ==========================================================================
# OPENTELEMETRY (traces + data logs + OTLP metrics bridge)
# OpenTelemetry configuration settings.
# ==========================================================================

# Enable OpenTelemetry tracing
# MERAKI_EXPORTER_OTEL__ENABLED=false

# OpenTelemetry collector endpoint (OTLP gRPC)
# MERAKI_EXPORTER_OTEL__ENDPOINT=

# Send OTLP traces over an insecure (non-TLS) channel. Set False to use
# TLS/system-trust-store transport to the collector endpoint.
# MERAKI_EXPORTER_OTEL__INSECURE=true

# Service name for OpenTelemetry tracing
# MERAKI_EXPORTER_OTEL__SERVICE_NAME=meraki-dashboard-exporter

# Trace sampling rate (0.0-1.0). 0 disables sampling, 1 samples every trace,
# values in between use ratio-based parent sampling. (min: 0.0, max: 1.0)
# MERAKI_EXPORTER_OTEL__SAMPLING_RATE=0.1

# Additional resource attributes for OpenTelemetry
# MERAKI_EXPORTER_OTEL__RESOURCE_ATTRIBUTES=

# Enable the OTLP data-log emitter for high-cardinality per-entity product
# data. Independent of otel.enabled (tracing). Off by default.
# MERAKI_EXPORTER_OTEL__LOGS__ENABLED=false

# OTLP gRPC endpoint for data logs. When None, falls back to otel.endpoint. An
# endpoint must resolve (own or inherited) when logs.enabled is True.
# MERAKI_EXPORTER_OTEL__LOGS__ENDPOINT=

# Send OTLP data logs over an insecure (non-TLS) channel. When None, inherits
# otel.insecure.
# MERAKI_EXPORTER_OTEL__LOGS__INSECURE=

# PII opt-in. When False (default), the emitter drops identifier attributes
# (client.mac / client.hostname / client.description) from every record; only
# stable IDs (client.id) are emitted. Set True to include the human-readable
# identifiers.
# MERAKI_EXPORTER_OTEL__LOGS__INCLUDE_IDENTIFIERS=false

# Per-data-class allowlist of built-in data-log event names (see DataLogEvent
# in core/otel_data_logs.py, e.g. "meraki.wireless.client.packet_loss"). None
# (default) enables all built-in events; an explicit list enables only the
# named events. Env: JSON array.
# MERAKI_EXPORTER_OTEL__LOGS__EVENTS=

# Enable the OTLP metrics bridge (push a periodic snapshot of the Prometheus
# registry via OTLP gRPC). Independent of otel.enabled (tracing) and
# otel.logs.enabled. Off by default; the /metrics scrape is unchanged either
# way.
# MERAKI_EXPORTER_OTEL__METRICS__ENABLED=false

# OTLP gRPC endpoint for metrics. When None, falls back to otel.endpoint. Must
# resolve (own or inherited) when metrics.enabled is True.
# MERAKI_EXPORTER_OTEL__METRICS__ENDPOINT=

# Send OTLP metrics over an insecure (non-TLS) channel. When None, inherits
# otel.insecure.
# MERAKI_EXPORTER_OTEL__METRICS__INSECURE=

# Seconds between registry snapshots pushed via OTLP. (min: 10, max: 3600)
# MERAKI_EXPORTER_OTEL__METRICS__EXPORT_INTERVAL_SECONDS=60

# Which telemetry plane to push, keyed on the metric-name prefix split:
# "product" = meraki_* excluding meraki_exporter_*; "self" = everything else
# (meraki_exporter_* plus the process/python runtime families); "all" = both.
# MERAKI_EXPORTER_OTEL__METRICS__INCLUDE=all

# Counter/histogram temporality. v1 accepts only 'cumulative' (Grafana Cloud
# expects cumulative; prometheus_client counters are cumulative-since-start,
# so this is the only faithful translation).
# MERAKI_EXPORTER_OTEL__METRICS__TEMPORALITY=cumulative

# Path to a CA certificate (PEM) used to verify the OTLP collector's TLS
# certificate, shared by all three OTLP channels (traces, data logs, metrics).
# Paths only - no inline PEM material (#314).
# MERAKI_EXPORTER_OTEL__CA_CERT_PATH=

# Path to a client certificate (PEM) for mTLS to the OTLP collector, shared by
# all three OTLP channels. Must be set together with client_key_path (#314).
# MERAKI_EXPORTER_OTEL__CLIENT_CERT_PATH=

# Path to a client private key (PEM) for mTLS to the OTLP collector, shared by
# all three OTLP channels. Must be set together with client_cert_path (#314).
# MERAKI_EXPORTER_OTEL__CLIENT_KEY_PATH=

# ==========================================================================
# MONITORING & HEALTH
# Monitoring and observability settings.
# ==========================================================================

# Maximum consecutive failures before alerting (min: 1, max: 100)
# MERAKI_EXPORTER_MONITORING__MAX_CONSECUTIVE_FAILURES=10

# Histogram buckets for collector duration metrics
# MERAKI_EXPORTER_MONITORING__HISTOGRAM_BUCKETS=[0.1, 0.5, 1.0, 2.5, 5.0, 10.0, 30.0, 60.0, 120.0, 300.0]

# Days before license expiration to start warning (min: 7, max: 90)
# MERAKI_EXPORTER_MONITORING__LICENSE_EXPIRATION_WARNING_DAYS=30

# Multiplier for metric TTL (collection_interval * multiplier) (min: 1.0, max:
# 10.0)
# MERAKI_EXPORTER_MONITORING__METRIC_TTL_MULTIPLIER=2.0

# Maximum number of tracked label sets per collector before shedding oldest
# (min: 100, max: 1000000)
# MERAKI_EXPORTER_MONITORING__MAX_CARDINALITY_PER_COLLECTOR=10000

# Dead-man switch threshold. /health returns 503 once no collector has
# completed a successful run within this many seconds, so Kubernetes/Docker
# restart a wedged exporter instead of leaving it serving stale metrics. 0
# (default) auto-derives the threshold from the fastest *enabled* tier's
# interval (3 x that interval), so a stalled fast loop trips liveness promptly
# without slower tiers causing false positives. Set a large value to
# effectively disable. (min: 0, max: 86400)
# MERAKI_EXPORTER_MONITORING__LIVENESS_MAX_STALE_SECONDS=0

# ==========================================================================
# COLLECTOR TOGGLES & BEHAVIOUR
# Collector-specific settings.
# ==========================================================================

# Enabled collector names
# MERAKI_EXPORTER_COLLECTORS__ENABLED_COLLECTORS=["alerts", "clients", "config", "device", "insight", "mtsensor", "mtsensoralerts", "networkhealth", "organization"]

# Explicitly disabled collectors (overrides enabled)
# MERAKI_EXPORTER_COLLECTORS__DISABLE_COLLECTORS=

# Timeout for individual collector runs in seconds (min: 30, max: 600)
# MERAKI_EXPORTER_COLLECTORS__COLLECTOR_TIMEOUT=240

# Collect per-AP wireless signal quality (RSSI/SNR). Costs ONE API call per
# selected AP per cycle (hourly cadence; no bulk endpoint exists). Scope the
# fan-out with ap_signal_quality_tags, or disable entirely.
# MERAKI_EXPORTER_COLLECTORS__COLLECT_AP_SIGNAL_QUALITY=true

# Meraki device tags scoping AP signal-quality collection. Empty = all APs;
# non-empty = only APs carrying at least one of these tags (CSV or JSON
# array).
# MERAKI_EXPORTER_COLLECTORS__AP_SIGNAL_QUALITY_TAGS=

# Enable the Meraki Insight collector (license-gated WAN/application health).
# Off by default; degrades to a debug-level skip when the org lacks Insight.
# MERAKI_EXPORTER_COLLECTORS__COLLECT_INSIGHT=false

# When collect_insight is on, also fan out per-network application health (one
# call per network x monitored application per cycle).
# MERAKI_EXPORTER_COLLECTORS__INSIGHT_APP_HEALTH_ENABLED=true

# ==========================================================================
# CARDINALITY GUARD
# Metric cardinality guard-rail settings (SCALE-01 / #540 family).
# ==========================================================================

# Maximum number of active time series permitted per metric family (metric
# name). When a family exceeds this, ``action`` decides what happens. (min:
# 100, max: 10000000)
# MERAKI_EXPORTER_CARDINALITY__MAX_SERIES_PER_FAMILY=50000

# What to do when a metric family exceeds max_series_per_family: 'warn' logs
# and keeps emitting; 'drop' stops emitting new series for that family.
# MERAKI_EXPORTER_CARDINALITY__ACTION=warn

# Metric family names to disable entirely (never emitted). Accepts a comma-
# separated string or a JSON array via env
# (MERAKI_EXPORTER_CARDINALITY__DISABLED_METRICS=a,b,c).
# MERAKI_EXPORTER_CARDINALITY__DISABLED_METRICS=

# How often (seconds) the cardinality monitor samples the registry. (min: 10,
# max: 3600)
# MERAKI_EXPORTER_CARDINALITY__MONITOR_INTERVAL_SECONDS=300

# Maximum distinct values retained per label when the cardinality monitor
# tracks label-value breakdowns, bounding the monitor's own memory. (min: 1,
# max: 100000)
# MERAKI_EXPORTER_CARDINALITY__MONITOR_MAX_LABEL_VALUES=100

# ==========================================================================
# CLIENT / PER-USER COLLECTION
# Client data collection settings.
# ==========================================================================

# Enable client data collection
# MERAKI_EXPORTER_CLIENTS__ENABLED=false

# DNS lookup timeout in seconds (min: 0.5, max: 10.0)
# MERAKI_EXPORTER_CLIENTS__DNS_TIMEOUT=5.0

# DNS cache TTL in seconds (default: 6 hours) (min: 300, max: 86400)
# MERAKI_EXPORTER_CLIENTS__DNS_CACHE_TTL=21600

# Maximum number of reverse-DNS cache entries (and per-client IP-tracking
# entries) held in memory. When exceeded, expired entries are pruned first,
# then the oldest entries are evicted so RSS stays bounded under sustained
# client churn (#543). (min: 1000, max: 5000000)
# MERAKI_EXPORTER_CLIENTS__DNS_CACHE_MAX_ENTRIES=100000

# Client cache TTL in seconds (for ID/hostname mappings, not metrics) (min:
# 300, max: 86400)
# MERAKI_EXPORTER_CLIENTS__CACHE_TTL=3600

# Maximum clients to track per network (min: 100, max: 50000)
# MERAKI_EXPORTER_CLIENTS__MAX_CLIENTS_PER_NETWORK=10000

# Global cap on clients emitted as metric series across ALL networks per
# collection cycle. Clients beyond the cap are dropped from metric emission
# with a warning and counted in meraki_exporter_clients_over_cap. (min: 100,
# max: 1000000)
# MERAKI_EXPORTER_CLIENTS__MAX_CLIENTS_TOTAL=25000

# Enable per-client wireless signal quality (RSSI/SNR) collection. Costs one
# API call per wireless client per cycle (interval-gated); prohibitively
# expensive at scale, so disabled by default.
# MERAKI_EXPORTER_CLIENTS__SIGNAL_QUALITY_ENABLED=false

# ==========================================================================
# NETWORK FILTER (restrict scraping to a subset of networks)
# Network-level filter for restricting which networks are scraped.
# ==========================================================================

# Network name globs to include. Supports * and ? wildcards.
# MERAKI_EXPORTER_NETWORK_FILTER__INCLUDE_NAMES=

# Exact network IDs (e.g. L_xxx) to include.
# MERAKI_EXPORTER_NETWORK_FILTER__INCLUDE_IDS=

# Network tags to include. A network matches if it carries any of these tags.
# MERAKI_EXPORTER_NETWORK_FILTER__INCLUDE_TAGS=

# Network name globs to exclude. Applied AFTER includes.
# MERAKI_EXPORTER_NETWORK_FILTER__EXCLUDE_NAMES=

# Exact network IDs to exclude.
# MERAKI_EXPORTER_NETWORK_FILTER__EXCLUDE_IDS=

# Network tags to exclude.
# MERAKI_EXPORTER_NETWORK_FILTER__EXCLUDE_TAGS=

# ==========================================================================
# ADAPTIVE SCHEDULER
# Adaptive budget-aware API scheduler settings (#617).
# ==========================================================================

# 'adaptive' (default): solver stretches endpoint-group intervals to fit the
# API budget. 'fixed': floors/pins only, no stretching, no AIMD (transition
# fallback).
# MERAKI_EXPORTER_SCHEDULER__MODE=adaptive

# Fraction of the effective budget the solver plans to; headroom absorbs
# bursts. (min: 0.1, max: 1.0)
# MERAKI_EXPORTER_SCHEDULER__TARGET_UTILIZATION=0.7

# Per-group interval cap as a multiple of its volatility floor. (min: 1.0,
# max: 16.0)
# MERAKI_EXPORTER_SCHEDULER__MAX_STRETCH_FACTOR=4.0

# Absolute per-group interval cap. (min: 300, max: 86400)
# MERAKI_EXPORTER_SCHEDULER__MAX_INTERVAL_SECONDS=3600

# How often the solver recomputes from org shape (matches inventory TTL).
# (min: 60, max: 86400)
# MERAKI_EXPORTER_SCHEDULER__RESOLVE_INTERVAL_SECONDS=900

# 429/Retry-After budget feedback (adaptive mode only).
# MERAKI_EXPORTER_SCHEDULER__AIMD_ENABLED=true

# (min: 0.1, max: 0.9)
# MERAKI_EXPORTER_SCHEDULER__AIMD_BACKOFF_MULTIPLIER=0.5

# (min: 0.01, max: 5.0)
# MERAKI_EXPORTER_SCHEDULER__AIMD_RECOVERY_RPS_PER_MINUTE=0.1

# (min: 0.05, max: 1.0)
# MERAKI_EXPORTER_SCHEDULER__AIMD_RESOLVE_HYSTERESIS=0.2

# Per-group interval pins, e.g. {"nh_connection_stats": 900}. Pinned groups
# are excluded from solver stretching. Env: JSON object.
# MERAKI_EXPORTER_SCHEDULER__GROUP_INTERVAL_OVERRIDES=
